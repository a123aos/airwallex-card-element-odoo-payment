<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_form_airwallex" model="ir.ui.view">
        <field name="name">payment.provider.form.airwallex</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//group[@name='provider_credentials']" position="inside">
                <group string="Airwallex Credentials" invisible="code != 'airwallex'">
                    <field name="airwallex_client_id" required="code == 'airwallex'"/>
                    <field name="airwallex_api_key" password="True" required="code == 'airwallex'"/>
                    
                    <div class="o_row mt-2" invisible="code != 'airwallex'">
                        <button name="action_airwallex_sync_methods" 
                                type="object" 
                                string="Sync Payment Methods" 
                                class="btn btn-primary" 
                                icon="fa-refresh"
                                help="從 Airwallex 帳號同步已啟用的支付方式"/>
                    </div>
                </group>
            </xpath>

        </field>
    </record>
</odoo>