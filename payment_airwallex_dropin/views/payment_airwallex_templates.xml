<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="airwallex_inline_form">
        <div name="o_airwallex_container" 
             class="w-100 mt-2 airwallex-container d-none" 
             style="min-height: 120px;">
            
            <div id="airwallex-card-element" class="form-control" style="min-height: 45px; padding: 10px 12px;"/>
            
            <div class="text-danger mt-2 airwallex-error-msg d-none"/>
            
            <div class="text-center p-3 airwallex-loading">
                <i class="fa fa-circle-o-notch fa-spin text-primary" style="font-size: 1.5rem;"/>
                <div class="mt-2 text-muted">正在安全連線至 Airwallex...</div>
            </div>
        </div>
    </template>

    <template id="payment_method_form_airwallex" inherit_id="payment.method_form">
        <xpath expr="//input[@name='o_payment_radio']" position="attributes">
            <attribute name="t-att-data-airwallex-config">
                provider_sudo.code == 'airwallex' and provider_sudo._get_airwallex_inline_form_values()
            </attribute>
        </xpath>
        
        <xpath expr="//div[@name='o_payment_inline_form']" position="inside">
            <t t-if="provider_sudo.code == 'airwallex'">
                <t t-call="payment_airwallex_dropin.airwallex_inline_form"/>
            </t>
        </xpath>
    </template>
</odoo>