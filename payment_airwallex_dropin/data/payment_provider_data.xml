<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="payment_provider_airwallex" model="payment.provider">
            <field name="name">Airwallex</field>
            <field name="code">airwallex</field>
            <field name="state">test</field>
            <!-- 默认不发布 -->
            <field name="is_published" eval="True"/>

            <!-- ✅ 修正：与 payment_provider.py 的 support_tokenization=True 一致 -->
            <field name="allow_tokenization" eval="True"/>

            <!-- 模块图标 -->
            <field name="image_128" type="base64" file="payment_airwallex_dropin/static/description/icon.png"/>

            <!-- 支持的支付方式 -->
            <field name="payment_method_ids" eval="[(6, 0, [
                ref('payment_method_card'),
                ref('payment_method_alipay'),
                ref('payment_method_wechat')
            ])]"/>
        </record>
    </data>
</odoo>