<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="payment_provider_airwallex" model="payment.provider">
        <field name="name">Airwallex</field>
        <field name="code">airwallex</field>
        <field name="is_published">True</field>
        <field name="inline_form_view_id" ref="airwallex_inline_form"/>
        <field name="state">test</field>
    </record>

    <record id="payment_provider_airwallex" model="payment.provider">
    <field name="payment_method_ids" eval="[(6, 0, [
        ref('payment.payment_method_card'),
        ref('payment.payment_method_alipay'),
        ref('payment.payment_method_wechat_pay')
    ])]"/>
</record>
</odoo>